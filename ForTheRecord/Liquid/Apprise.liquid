To: {{ to | default: "me" }}
From: {{ from | default: "Apprise via ForTheRecord <me>" }}
X-FTR-Gmail-LabelID: {{ gmail_label_id | default: "INBOX" }}
{% if type == "failure" or gmail_starred -%}
X-FTR-Gmail-LabelID: STARRED
{% endif -%}
{% if gmail_important -%}
X-FTR-Gmail-LabelID: IMPORTANT
{% endif -%}
{% if gmail_internal_date_source -%}
X-FTR-Gmail-InternalDateSource: {{ gmail_internal_date_source }}
{% endif -%}
{% if gmail_never_mark_spam -%}
X-FTR-Gmail-NeverMarkSpam: {{ gmail_never_mark_spam }}
{% endif -%}
{% if gmail_process_for_calendar -%}
X-FTR-Gmail-ProcessForCalendar: {{ gmail_process_for_calendar }}
{% endif -%}
{% if gmail_deleted -%}
X-FTR-Gmail-Deleted: {{ gmail_deleted }}
{% endif -%}
{% capture type -%}
  {% case type -%}
    {%- when "info" %}📢
    {%- when "success" %}✅
    {%- when "failure" %}❌
    {%- when "warning" %}⚠️
  {%- endcase -%}
{% endcapture -%}
{% capture subject -%}
  {% if type != "" -%}{{ type }} {% endif %}{{ title }}
{%- endcapture -%}
Subject: {{ subject | ftr_encode_utf8 }}
Content-Type: multipart/mixed; boundary={{ ftr.guid }}

--{{ ftr.guid }}
{% case ftr_input_format -%}
  {%- when "html" -%}
Content-Type: text/html

{{ message }}
  {%- when "markdown" -%}
Content-Type: text/html

{{ message | ftr_markdown }}
  {%- else -%}
Content-Type: text/plain

{{ message }}
{% endcase -%}
{% for attach in attachments -%}
--{{ ftr.guid }}
Content-Type: {{ attach.mimetype }}; name="{{ attach.filename | escape }}"
Content-Disposition: attachment; filename="{{ attach.filename | escape }}"
Content-Transfer-Encoding: base64

{{ attach.base64 }}
{% endfor -%}
--{{ ftr.guid }}--